{
  "name": "yihuaxiang-github-page",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "predev": "node scripts/sync-projects.mjs && node scripts/use-template.mjs",
    "sync:projects": "node scripts/sync-projects.mjs",
    "prebuild": "node scripts/sync-projects.mjs && node scripts/use-template.mjs",
    "build": "npm run build:client && npm run build:ssr && node scripts/prerender.mjs && node scripts/export-root.mjs",
    "build:client": "vite build",
    "build:ssr": "vite build --ssr src/entry-server.jsx --outDir .ssr-temp",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "vite": "^8.0.16",
    "@vitejs/plugin-react": "^6.0.2"
  }
}
